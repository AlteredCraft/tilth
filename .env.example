# Provider configuration. Tilth talks to any OpenAI-compatible endpoint.
# Defaults below point at Ollama Cloud. Switch base_url + api_key to use
# OpenRouter, Together, Groq, Anyscale, Fireworks, vLLM, LM Studio, etc.

# TILTH_BASE_URL=https://openrouter.ai/api/v1
TILTH_BASE_URL=https://ollama.com/v1
TILTH_API_KEY=your_api_key_here
TILTH_WORKER_MODEL=gpt-oss:120b-cloud

# Judge model. Defaults to the worker if TILTH_JUDGE_MODEL is unset.
#
# Routing the judge to a *different provider* (set TILTH_JUDGE_BASE_URL +
# TILTH_JUDGE_API_KEY) is mostly about INDEPENDENCE, not cost. Cross-family
# judging (worker = open model, judge = Claude/GPT) catches failure modes a
# same-family judge will miss.
#
# As a rule, the judge should be AT LEAST as capable as the worker — for code
# diff review, a weaker judge silently accepts bad work because it doesn't
# notice the problem. "Cheap judge" only works for shallow checks (binary,
# regex, policy gates), not for correctness gating in a Ralph loop.
# TILTH_JUDGE_BASE_URL=https://openrouter.ai/api/v1
TILTH_JUDGE_MODEL=gpt-oss:120b-cloud
# TILTH_JUDGE_API_KEY=sk-or-...

# Safety caps.
TILTH_MAX_ITERATIONS_PER_TASK=8
TILTH_MAX_WALL_CLOCK_MINUTES=120
TILTH_MAX_TOKENS=2000000

# Required for OpenRouter thinking-mode models (deepseek-v4, qwen3-thinking, etc.)
# with tool calling — see USAGE.md for details. Set to false only if your
# provider rejects unknown body fields.
TILTH_REASONING_ENABLED=true
