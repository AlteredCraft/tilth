# Provider configuration. The harness talks to any OpenAI-compatible endpoint.
# Defaults below point at Ollama Cloud. Switch base_url + api_key to use
# OpenRouter, Together, Groq, Anyscale, Fireworks, vLLM, LM Studio, etc.

# HARNESS_BASE_URL=https://openrouter.ai/api/v1
HARNESS_BASE_URL=https://ollama.com/v1
HARNESS_API_KEY=your_api_key_here
HARNESS_WORKER_MODEL=gpt-oss:120b-cloud

# Judge model. Defaults to the worker if HARNESS_JUDGE_MODEL is unset.
#
# Routing the judge to a *different provider* (set HARNESS_JUDGE_BASE_URL +
# HARNESS_JUDGE_API_KEY) is mostly about INDEPENDENCE, not cost. Cross-family
# judging (worker = open model, judge = Claude/GPT) catches failure modes a
# same-family judge will miss.
#
# As a rule, the judge should be AT LEAST as capable as the worker — for code
# diff review, a weaker judge silently accepts bad work because it doesn't
# notice the problem. "Cheap judge" only works for shallow checks (binary,
# regex, policy gates), not for correctness gating in a Ralph loop.
# HARNESS_JUDGE_BASE_URL=https://openrouter.ai/api/v1
HARNESS_JUDGE_MODEL=gpt-oss:120b-cloud
# HARNESS_JUDGE_API_KEY=sk-or-...

# Safety caps.
HARNESS_MAX_ITERATIONS_PER_TASK=8
HARNESS_MAX_WALL_CLOCK_MINUTES=120
HARNESS_MAX_TOKENS=2000000
