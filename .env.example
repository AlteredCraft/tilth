# Provider configuration. Tilth talks to an OpenAI-compatible endpoint.
# All three of these are REQUIRED — Tilth refuses to start without them.
# Tilth is tested against OpenRouter today; other OpenAI-flavour gateways
# should work via the OpenAI SDK but haven't been validated yet.

TILTH_BASE_URL=https://openrouter.ai/api/v1
TILTH_API_KEY=sk-or-your_api_key_here
TILTH_WORKER_MODEL=deepseek/deepseek-v4-pro

# Judge model. Defaults to the worker if TILTH_JUDGE_MODEL is unset.
#
# Routing the judge to a *different provider* (set TILTH_JUDGE_BASE_URL +
# TILTH_JUDGE_API_KEY) is mostly about INDEPENDENCE, not cost. Cross-family
# judging (e.g. open-source worker, frontier closed judge) catches failure
# modes a same-family judge will miss.
#
# As a rule, the judge should be AT LEAST as capable as the worker — for code
# diff review, a weaker judge silently accepts bad work because it doesn't
# notice the problem. "Cheap judge" only works for shallow checks (binary,
# regex, policy gates), not for correctness gating in a Ralph loop.
TILTH_JUDGE_MODEL=anthropic/claude-sonnet-4.5

# Safety caps.
TILTH_MAX_ITERATIONS_PER_TASK=32
TILTH_MAX_WALL_CLOCK_MINUTES=120
TILTH_MAX_TOKENS=2000000

# Optional cap on judge calls per task. The judge runs every time the worker
# claims "done" and validators pass; a stuck task can ping-pong worker↔judge
# and burn the whole token budget on one PRD item. Set this to halt a task
# after N judge rejections (the task is marked failed, the run stops). Unset
# or 0 = unlimited.
# TILTH_MAX_JUDGE_CALLS_PER_TASK=3
